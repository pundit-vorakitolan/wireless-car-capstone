import pygame
pygame.init()
pygame.joystick.init()

if pygame.joystick.get_count() == 0:
    print("No joystick found!")
else:
    wheel = pygame.joystick.Joystick(0)
    wheel.init()
    print(f"Found: {wheel.get_name()}")
    print(f"Axes: {wheel.get_numaxes()}, Buttons: {wheel.get_numbuttons()}")
    
    clock = pygame.time.Clock()
    while True:
        pygame.event.pump()
        axes = [round(wheel.get_axis(i), 2) for i in range(wheel.get_numaxes())]
        print(f"\rAxes: {axes}   ", end="", flush=True)
        clock.tick(30)